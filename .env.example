# ==============================================
# APPLICATION SETTINGS
# ==============================================
APP_NAME="XevouZK"
APP_ENV=local #production untuk deploy
APP_KEY= #Generate dengan: php artisan key:generate --show
APP_DEBUG=true #false untuk deploy
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://xevouzk.test #Harus cocok dengan domain Herd: jalankan `herd link xevouzk`
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=zk_payment
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# ==============================================
# POLYGON BLOCKCHAIN - TESTNET (AMOY)
# ==============================================
POLYGON_NETWORK=testnet
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
POLYGON_CHAIN_ID=80002
# RPC UPSTREAM untuk SCAN dana masuk (eth_getLogs historis). Dipakai HANYA oleh
# proxy server (POST /payment/scan-rpc) — URL berisi API key ini TIDAK pernah
# dikirim ke peramban. RPC publik gratis kini menutup getLogs historis (publicnode
# minta token archive; resmi/drpc batasi ~100 blok), jadi scan transfer masuk
# WAJIB pakai RPC ber-API-key, mis. Alchemy Amoy:
#   POLYGON_SCAN_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/<API_KEY>
# (Aktifkan jaringan Polygon Amoy di dashboard Alchemy lebih dulu.)
POLYGON_SCAN_RPC_URL=https://polygon-amoy-bor-rpc.publicnode.com
# ZKPayment v2 + 3 verifier (deploy artifacts; lihat docs/PROJECT-STATUS.md §2).
# Untuk redeploy lihat docs/DEPLOY-GUIDE.md.
POLYGON_CONTRACT_ADDRESS=0xYourZKPaymentContractAddress
# Blok deploy ZKPayment — lantai scan event EncryptedNote (terima dana privat).
# Set ke blok deploy kontrak (atau sedikit di bawahnya). 0 = scan dari genesis
# (TIDAK disarankan di Amoy: puluhan juta blok → scan menggantung / rate-limit).
POLYGON_CONTRACT_DEPLOY_BLOCK=0
POLYGON_BALANCE_VERIFIER_ADDRESS=0xYourBalanceVerifierAddress
POLYGON_TRANSFER_VERIFIER_ADDRESS=0xYourTransferVerifierAddress
POLYGON_WITHDRAW_VERIFIER_ADDRESS=0xYourWithdrawVerifierAddress
# MASTER WALLET — wallet "panas" runtime untuk faucet + tx outbound server.
# Key runtime (lokal Herd; boleh di hosting bila nanti di-deploy). Sengaja TIDAK
# punya hak owner kontrak (least privilege). JANGAN commit value asli.
POLYGON_PRIVATE_KEY=your_64char_hex_master_key_here
POLYGON_MASTER_WALLET=0xYourTestnetMasterWalletAddress

# ==============================================
# POLYGON BLOCKCHAIN - MAINNET
# Uncomment dan ganti values di atas jika deploy ke mainnet
# ==============================================
# POLYGON_NETWORK=mainnet
# POLYGON_RPC_URL=https://polygon-rpc.com/
# POLYGON_CHAIN_ID=137
# POLYGON_CONTRACT_ADDRESS=0xYourMainnetContractAddress
# POLYGON_PRIVATE_KEY=your_mainnet_private_key_64chars
# POLYGON_MASTER_WALLET=0xYourMainnetWalletAddress

# ==============================================
# SMART CONTRACT DEPLOYMENT (Hardhat) — wallet "dingin"
# DEPLOYER terpisah dari MASTER (prinsip least privilege). Wallet yang men-deploy
# otomatis jadi owner kontrak — hanya hidup di laptop developer, JANGAN di hosting.
# Lihat .env.production.example untuk template hosting (deployer key dihapus).
# ==============================================
DEPLOYER_PRIVATE_KEY=your_64char_hex_deployer_key_here
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology/
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com/
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ==============================================
# ZK-SNARK CONFIGURATION
# ==============================================
ZK_ENABLED=true
ZK_CIRCUIT_PATH=storage/circuits/
ZK_PROVING_KEY_PATH=storage/keys/proving_key.json
ZK_VERIFICATION_KEY_PATH=storage/keys/verification_key.json

# ==============================================
# QR CODE CONFIGURATION
# ==============================================
QR_CODE_SIZE=300
QR_CODE_FORMAT=png
QR_CODE_ERROR_CORRECTION=M

# ==============================================
# SESSION & CACHE
# ==============================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
# true: cookie sesi mati saat browser ditutup (logout) kecuali "Ingat saya" aktif
SESSION_EXPIRE_ON_CLOSE=true
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

# ==============================================
# QUEUE CONFIGURATION
# ==============================================
QUEUE_CONNECTION=database

# ==============================================
# LOGGING
# ==============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ==============================================
# BROADCASTING
# ==============================================
BROADCAST_CONNECTION=log

# ==============================================
# MAIL CONFIGURATION (Optional)
# ==============================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================
# AWS S3 (Optional - Uncomment jika pakai)
# ==============================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ==============================================
# PUSHER (Optional - Uncomment jika pakai)
# ==============================================
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=mt1

# ==============================================
# FILESYSTEM
# ==============================================
FILESYSTEM_DISK=public

# ==============================================
# VITE CONFIGURATION
# ==============================================
VITE_APP_NAME="${APP_NAME}"

# ==============================================
