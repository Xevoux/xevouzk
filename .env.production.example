# ==============================================
# XevouZK — TEMPLATE .env UNTUK HOSTING / PRODUCTION
# ==============================================
# File ini adalah turunan .env.example dengan adjustment untuk deployment:
#   - APP_ENV=production, APP_DEBUG=false
#   - DEPLOYER_PRIVATE_KEY DIHILANGKAN (prinsip least privilege)
#   - APP_KEY harus di-generate ulang di server
#   - Database & MAIL menyesuaikan provider hosting
#
# Copy file ini ke `.env` di server, lalu isi value asli. JANGAN commit .env.
# ==============================================

# ==============================================
# APPLICATION SETTINGS
# ==============================================
APP_NAME="XevouZK"
APP_ENV=production
APP_KEY= # generate di server: php artisan key:generate --show
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://your-hosting-domain.example
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# ==============================================
# DATABASE CONFIGURATION
# Sesuaikan dengan kredensial DB di hosting (cPanel / managed DB / dsb.)
# ==============================================
DB_CONNECTION=mysql
DB_HOST=your_db_host
DB_PORT=3306
DB_DATABASE=your_db_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ==============================================
# POLYGON BLOCKCHAIN - TESTNET (AMOY)
# Address kontrak SAMA dengan yang sudah ter-deploy.
# Hosting TIDAK deploy ulang — hanya pakai address-nya.
# ==============================================
POLYGON_NETWORK=testnet
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
POLYGON_CHAIN_ID=80002
# SPEC-009 v2 deploy 2026-05-21: 4 kontrak (Balance + Transfer + Withdraw + ZKPayment v2).
# Owner kontrak = DEPLOYER 0xF90BA9...Adf4 (least privilege — key TIDAK ada di file ini).
POLYGON_CONTRACT_ADDRESS=0x2C6ac9CFd88167366Ceb31a50D2ad766067b4259
POLYGON_BALANCE_VERIFIER_ADDRESS=0x37eAF29fdfbd663f2a4778C4424dfBCe7A7C709D
POLYGON_TRANSFER_VERIFIER_ADDRESS=0xF709a2AA78fd8Dc6495CD7787a8df5A155deA256
POLYGON_WITHDRAW_VERIFIER_ADDRESS=0xCd07612eFc45A0Ed476FF77E0aDd524198C3A7D3

# MASTER wallet — satu-satunya private key yang hidup di hosting.
# Dipakai oleh FaucetService + PolygonService::sendTransaction.
# Kalau hosting kena hack, kerugian terbatas: penyerang dapat saldo faucet,
# TIDAK dapat hak owner kontrak (owner ada di wallet DEPLOYER yang tidak ada di sini).
POLYGON_MASTER_WALLET=0xYourMasterWalletAddress
POLYGON_PRIVATE_KEY=your_64char_master_private_key_no_0x_prefix

# ==============================================
# SMART CONTRACT DEPLOYMENT (Hardhat)
# DEPLOYER_PRIVATE_KEY SENGAJA TIDAK ADA di file ini (prinsip least privilege).
# Deploy kontrak dilakukan dari laptop developer, BUKAN dari server hosting.
# Lihat docs/PROJECT-STATUS.md §8 "Security posture".
# ==============================================
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology/
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com/
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ==============================================
# ZK-SNARK CONFIGURATION
# Pastikan storage/app/zk-keys/ dan public/zk/ ter-upload ke server.
# ==============================================
ZK_ENABLED=true
ZK_CIRCUIT_PATH=storage/circuits/
ZK_PROVING_KEY_PATH=storage/keys/proving_key.json
ZK_VERIFICATION_KEY_PATH=storage/keys/verification_key.json

# ==============================================
# QR CODE CONFIGURATION
# ==============================================
QR_CODE_SIZE=300
QR_CODE_FORMAT=png
QR_CODE_ERROR_CORRECTION=M

# ==============================================
# SESSION & CACHE
# Untuk production: pertimbangkan redis kalau hosting support.
# ==============================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

# ==============================================
# QUEUE CONFIGURATION
# ==============================================
QUEUE_CONNECTION=database

# ==============================================
# LOGGING
# Production: LOG_LEVEL=error supaya log tidak penuh.
# ==============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ==============================================
# BROADCASTING
# ==============================================
BROADCAST_CONNECTION=log

# ==============================================
# MAIL CONFIGURATION
# Sesuaikan dengan SMTP provider hosting (Mailgun / SES / SMTP cPanel).
# ==============================================
MAIL_MAILER=smtp
MAIL_HOST=your_smtp_host
MAIL_PORT=587
MAIL_USERNAME=your_smtp_user
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@your-hosting-domain.example"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================
# FILESYSTEM
# ==============================================
FILESYSTEM_DISK=public

# ==============================================
# VITE CONFIGURATION
# Production: jalankan `npm run build` lokal, lalu upload public/build/
# ==============================================
VITE_APP_NAME="${APP_NAME}"
