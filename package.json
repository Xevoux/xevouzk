{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "xevouzk",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "compile-circuits": "cd circuits && circom main.circom --r1cs --wasm --sym",
