        "vite": "^7.0.7",
        "vite-plugin-node-polyfills": "^0.28.0"
    },
    "dependencies": {
        "@noble/curves": "1.4.0",
        "@noble/hashes": "1.4.0",
        "circomlib": "^2.0.5",
        "circomlibjs": "0.1.7",
        "ethers": "6.13.0",
        "ffjavascript": "^0.3.0",
        "html5-qrcode": "2.3.8",
        "lucide": "0.456.0",
        "qrcode": "^1.5.4",
        "snarkjs": "0.7.4",
        "web3": "^4.14.0"
    }
}
